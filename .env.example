# ========== БАЗА ДАННЫХ (Neon Postgres) ==========
# Пулированное подключение — используется приложением в рантайме на Vercel (serverless).
# Обычно содержит "-pooler" в хосте.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Прямое подключение — используется Prisma для миграций и seed (без пулера).
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ========== АУТЕНТИФИКАЦИЯ (Auth.js / NextAuth v5) ==========
# Сгенерировать: npx auth secret   (или: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-secret"
